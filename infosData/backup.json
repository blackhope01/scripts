      },
      {
        "explanation": "Sonuç veride çift tırnakları kaldır.",
        "command": "jq -r \".data\" test.json"
      },
      {
        "explanation": "Nesne içindeki Array de index numarası ile anahtar bulma.",
        "command": "jq -r '.[] | select(.commandName == \"find\" and .data[0].explanation != null) | .data[$i].explanation' infosData.json |tr -d '\\'"
      },
      {
        "explanation": "Yeni nesne ekleme.",
        "command": "jq -r '. += [{\"commandName\":\"'\"$1\"'\",\"data\":[{\"explanation\":\"'\"$explanation\"'\",\"command\":\"'\"$command\"'\"}]}]' $dataFile"
      },
      {
        "explanation": "Nesne içine ekleme yapma.",
        "command": "jq '. |= map(if .commandName == \"'\"$1\"'\" then .data += [{\"explanation\": \"'\"$explanation\"'\", \"command\": \"'\"$command\"'\"}] else . end)' $dataFile"
      },
      {
        "explanation": "Nesne içindeki Array içindeki nesneyi index numarası ile silme.",
        "command": "jq '.[] |= if .commandName == \"'\"$1\"'\" then del(.data['\"$3\"']) else . end' $dataFile"
      },
      {
        "explanation": "Nesne içindeki array içindeki nesne anahtar değerini değiştirme.",
        "command": "jq '.[] | select(.commandName == \"jq\") .data[2].command |= \"new\"' infosData.json"
      },
      {
        "explanation": "Anahtar içindeki değeri değiştirme.",
        "command": "jq '.[] | select(.commandName == \"jq\") .data[0].command |= sub(\"jq\"; \"json\")' infosData.json"
